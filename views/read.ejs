<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/head', { title: 'Oku — ' + book.title }) %>
  <style>
    .reader-body { background: #0c0c0a; font-family: var(--serif); }
    .reader-body .header { display: none; }
    .chapter-menu { position: fixed; top: 60px; left: 0; bottom: 0; width: 280px; background: rgba(5,5,8,0.97); border-right: 1px solid var(--border); z-index: 999; transform: translateX(-100%); transition: transform 0.3s ease; overflow-y: auto; padding: 20px; }
    .chapter-menu.active { transform: translateX(0); }
    .chapter-menu h3 { font-family: var(--serif); font-size: 1rem; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
    .chapter-menu-item { padding: 10px 12px; border-radius: var(--radius); margin-bottom: 4px; cursor: pointer; transition: var(--transition-fast); font-size: 0.85rem; font-family: var(--serif); color: var(--text-dim); }
    .chapter-menu-item:hover { background: var(--bg-hover); color: var(--text); }
    .chapter-menu-item.active { background: var(--accent-glow); color: var(--accent-bright); border-left: 2px solid var(--accent); }
    .chapter-menu-close { position: absolute; top: 10px; right: 10px; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: var(--text-dim); cursor: pointer; border-radius: 50%; transition: var(--transition-fast); }
    .chapter-menu-close:hover { color: var(--text); background: var(--bg-hover); }
    .reader-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 998; opacity: 0; visibility: hidden; transition: var(--transition-fast); }
    .reader-overlay.active { opacity: 1; visibility: visible; }
    @media (max-width: 768px) { .chapter-menu { width: 100%; } }
  </style>
</head>
<body class="reader-body">

  <% var bookChapters = locals.bookChapters || []; %>

  <div class="reader-overlay" id="readerOverlay" onclick="toggleChapterMenu()"></div>

  <div class="chapter-menu" id="chapterMenu">
    <div class="chapter-menu-close" onclick="toggleChapterMenu()">✕</div>
    <h3><%= book.title %></h3>
    <% if (bookChapters && bookChapters.length) { %>
      <% bookChapters.forEach((ch, i) => { %>
        <div class="chapter-menu-item <%= i === 0 ? 'active' : '' %>" onclick="loadChapter(<%= i %>)" data-index="<%= i %>">
          <%= String(i+1).padStart(2, '0') %>. <%= ch.title %>
        </div>
      <% }) %>
    <% } else { %>
      <p style="color: var(--text-muted); font-family: var(--serif); font-style: italic; font-size: 0.85rem;">Henüz bölüm yok.</p>
    <% } %>
  </div>

  <div class="reader-header">
    <div class="reader-header-left">
      <a href="/book/<%= book.slug %>" class="reader-back">←</a>
      <span class="reader-title"><%= book.title %> — <%= book.author %></span>
    </div>
    <div class="reader-header-right">
      <button class="reader-btn" onclick="toggleChapterMenu()" title="Bölümler">☰</button>
      <button class="reader-btn" onclick="toggleSettings()" title="Ayarlar">⚙</button>
      <button class="reader-btn" onclick="toggleBookmark()" title="Yer İmi" id="bookmarkBtn">☆</button>
    </div>
  </div>

  <div class="settings-panel" id="settingsPanel">
    <div class="settings-title">Okuma Ayarları</div>
    <div class="setting-row">
      <label>Yazı Boyutu</label>
      <div class="font-size-controls">
        <button onclick="changeFontSize(-2)">−</button>
        <span id="fontSizeVal">18</span>
        <button onclick="changeFontSize(2)">+</button>
      </div>
    </div>
    <div class="setting-row">
      <label>Arka Plan</label>
      <div class="theme-options">
        <div class="theme-option active" style="background:#0c0c0e;" onclick="setTheme('dark')" title="Koyu"></div>
        <div class="theme-option" style="background:#f5f0e8;" onclick="setTheme('light')" title="Açık"></div>
        <div class="theme-option" style="background:#1e2a1e;" onclick="setTheme('green')" title="Yeşil"></div>
        <div class="theme-option" style="background:#1e1e2e;" onclick="setTheme('blue')" title="Lacivert"></div>
      </div>
    </div>
    <div class="setting-row">
      <label>Yazı Tipi</label>
      <div class="font-family-options">
        <button class="font-family-option active" onclick="setFont('Merriweather')" style="font-family:Merriweather,serif;">Merriweather</button>
        <button class="font-family-option" onclick="setFont('Inter')" style="font-family:Inter,sans-serif;">Inter</button>
        <button class="font-family-option" onclick="setFont('Georgia')" style="font-family:Georgia,serif;">Georgia</button>
      </div>
    </div>
    <div class="setting-row">
      <label>Satır Aralığı</label>
      <div class="line-height-options">
        <button class="line-height-option" onclick="setLineHeight(1.5)">Dar</button>
        <button class="line-height-option active" onclick="setLineHeight(1.9)">Normal</button>
        <button class="line-height-option" onclick="setLineHeight(2.4)">Geniş</button>
      </div>
    </div>
  </div>

  <article class="reader-content" id="readerContent">
    <% if (bookChapters && bookChapters.length) { %>
      <h1 class="chapter-title" id="chapterTitle"><%= bookChapters[0].title %></h1>
      <div id="chapterBody">
        <% bookChapters[0].content.split('\n\n').forEach(p => { %>
          <% if (p.trim().startsWith('"') || p.trim().startsWith('“')) { %>
            <p class="epigraph"><%= p.trim() %></p>
          <% } else { %>
            <p><%= p.trim() %></p>
          <% } %>
        <% }) %>
      </div>
    <% } else { %>
      <h1 class="chapter-title">Bölüm 1</h1>
      <p class="epigraph">"Başlangıçta vardı... vardı... ama ne vardı? Bir şey vardı, işte o kadar."</p>
      <p>Yazın başlangıcındaydı, temmuzun sonuna doğru, aşırı bir sıcak çökmüştü Sankt-Petersburg şehrine. Öğleden sonra, saat dört ile beş arası, ağaçların yaprakları suskun ve hareketsiz duruyorlardı, dar ve tozlu caddelerdeki sıcak hava dayanılmaz bir ağırlıkla üzerlerine çökmüştü.</p>
      <p>Çok genç, yirmi üç yaşındaki bir adam, evden çıkıp dışarı adım attı. Raskolnikov denen bu genç adam, Moskova Üniversitesi Hukuk Fakültesi'nde okuyordu, ama şimdilerde Sankt-Petersburg'daydı ve üniversiteden kaydını sildirmiş, üstelik son derece yoksul, hatta neredeyse aç durumda yaşıyordu.</p>
      <p>Ev sahibesi ona tıpış tıpış bakıyor, hatta belki de kötü gözle bakıyordu. Genç adam bu yüzden ondan kaçınıyor, onu görmek istemiyordu. Gerçekten de onun aklında oldukça tuhaf bir şey vardı. Bu tuhaf şey, kafasına koyduğu bir şeydi, ama ne olduğunu henüz kendisi de tam olarak bilmiyordu.</p>
      <p>Sokağa çıktığında, sanki bir karar vermekten kaçınır gibi, alışılmadık bir telaşla kendisini sokağın sağ tarafına attı. Yolda rastladığı her şey ona hiç ilginç gelmiyor, hiçbir şey dikkatini çekmiyordu. Düşünceli, gülümseyen bir yüzle, bazen söylenerek yürüyordu.</p>
      <p>"Evet... benim gibi bir insanın... yoksul bir hukuk öğrencisinin... işleyebileceği bir suç... bu dünyada ne olabilir?" diye mırıldandı. "Yani şu önemsiz, kimsesiz, hasta, zavallı kadını öldürmek... bu bir suç mu? Hayır, bu bir suç değil. Bu bir adım. Bir adım ileriye gitmek, kendini kanıtlamak... evet, bu olağanüstü bir insanın yapacağı bir şey."</p>
      <p>Bu düşünceler onu iyice sarhoş etmişti. Sanki bir çeşit ateş basmıştı yüzünü. Gözleri parlıyordu. Şimdi ne yapacağını biliyordu. Artık geri dönüş yoktu. Büyük bir karar verilmişti ve bu karar onu hem heyecanlandırıyor hem de korkutuyordu.</p>
      <p>"Ya başarısız olursam?" diye düşündü aniden. "Ya yakalanırsam? O zaman?... Hayır, hayır, bu kadar basit olamaz. Her şeyi düşündüm, her ayrıntıyı planladım. Sadece... sadece cesaret. Evet, cesaret. Olağanüstü bir insan, olağanüstü bir adım atar. Ve ben olağanüstü biri değil miyim?"</p>
      <p>Ev sahibesinin evine dönerken, merdivenleri tırmanırken, kalbi çarpıyordu. O kadar hızlı çarpıyordu ki, neredeyse duyulabilecek kadar. Yukarı çıktı, kapıyı açtı, küçük odasına girdi. Oda dar, sıcak, tavanı alçaktı. Pencereden gelen ışık soluktu, tozlu, yıpranmış duvar kağıtları sarımsı bir renkteydi.</p>
      <p>Masaya oturdu, başını ellerinin arasına aldı. Saatlerce öylece kaldı. Sonra ayağa kalktı, cebinden eski, paslı bir bıçak çıkardı. Bıçağa baktı. Gözlerini kapattı. Derin bir nefes aldı.</p>
      <p>"Yarın. Yarın olacak. Her şey yarın belli olacak."</p>
      <p>Bu sözleri söylerken, sesi titremiyordu. Aksine, olağanüstü bir sakinlik vardı üzerinde. Sanki bir şey bitmiş, başka bir şey başlamıştı. Artık geri dönüşü olmayan bir yola girmişti. Ve bu yol, onu nereye götürecekti? Bunu henüz bilmiyordu. Ama biliyordu ki, bir adım atmak zorundaydı. Çünkü durduğu yerde, hiçbir şey olmayacaktı. Hiçbir şey.</p>
    <% } %>
  </article>

  <div class="reader-nav">
    <button class="reader-nav-btn" id="prevBtn" onclick="prevChapter()">← Önceki</button>
    <button class="reader-nav-btn" id="nextBtn" onclick="nextChapter()">Sonraki →</button>
  </div>

  <div class="reader-progress">
    <div class="reader-progress-bar" id="progressBar"></div>
  </div>
  <div class="reader-progress-text" id="progressText">%0</div>

  <div class="toast" id="toast"></div>

  <script src="/js/app.js"></script>
  <script>
    let currentFontSize = 18;
    let currentFont = 'Merriweather';
    let currentLineHeight = 1.9;
    let currentTheme = 'dark';
    let currentChapter = 0;

    const chapters = <%- JSON.stringify(bookChapters || []) %>;

    function toggleChapterMenu() {
      document.getElementById('chapterMenu').classList.toggle('active');
      document.getElementById('readerOverlay').classList.toggle('active');
    }

    function loadChapter(index) {
      if (index < 0 || index >= chapters.length) return;
      currentChapter = index;
      const ch = chapters[index];
      document.getElementById('chapterTitle').textContent = ch.title;

      const paragraphs = ch.content.split('\n\n').map(p => {
        const trimmed = p.trim();
        if (trimmed.startsWith('"') || trimmed.startsWith('"')) {
          return '<p class="epigraph">' + trimmed + '</p>';
        }
        return '<p>' + trimmed + '</p>';
      }).join('');
      document.getElementById('chapterBody').innerHTML = paragraphs;

      window.scrollTo(0, 0);
      toggleChapterMenu();
      updateNavButtons();

      document.querySelectorAll('.chapter-menu-item').forEach((el, i) => {
        el.classList.toggle('active', i === index);
      });
    }

    function prevChapter() {
      if (currentChapter > 0) loadChapter(currentChapter - 1);
    }

    function nextChapter() {
      if (currentChapter < chapters.length - 1) loadChapter(currentChapter + 1);
    }

    function updateNavButtons() {
      document.getElementById('prevBtn').classList.toggle('disabled', currentChapter === 0);
      document.getElementById('nextBtn').classList.toggle('disabled', currentChapter >= chapters.length - 1);
    }

    function toggleSettings() {
      document.getElementById('settingsPanel').classList.toggle('active');
    }

    function toggleBookmark() {
      const btn = document.getElementById('bookmarkBtn');
      const isMarked = btn.textContent === '★';
      btn.textContent = isMarked ? '☆' : '★';
      btn.style.color = isMarked ? '' : 'var(--accent)';
      showToast(isMarked ? 'Yer imi kaldırıldı' : 'Yer imi eklendi');
    }

    function changeFontSize(delta) {
      currentFontSize += delta;
      if (currentFontSize < 14) currentFontSize = 14;
      if (currentFontSize > 30) currentFontSize = 30;
      document.getElementById('fontSizeVal').textContent = currentFontSize;
      document.getElementById('readerContent').style.fontSize = currentFontSize + 'px';
    }

    function setTheme(theme) {
      currentTheme = theme;
      document.querySelectorAll('.theme-option').forEach(el => el.classList.remove('active'));
      event.target.classList.add('active');
      const body = document.body;
      const content = document.getElementById('readerContent');
      const header = document.querySelector('.reader-header');
      if (theme === 'dark') {
        body.style.background = '#0c0c0e'; content.style.color = '#e0e0e5'; header.style.background = 'rgba(12,12,14,0.97)';
      } else if (theme === 'light') {
        body.style.background = '#f5f0e8'; content.style.color = '#2c2c2c'; header.style.background = 'rgba(245,240,232,0.97)';
      } else if (theme === 'green') {
        body.style.background = '#1e2a1e'; content.style.color = '#d0d8d0'; header.style.background = 'rgba(30,42,30,0.97)';
      } else if (theme === 'blue') {
        body.style.background = '#1e1e2e'; content.style.color = '#d0d0e0'; header.style.background = 'rgba(30,30,46,0.97)';
      }
    }

    function setFont(font) {
      currentFont = font;
      document.querySelectorAll('.font-family-option').forEach(el => el.classList.remove('active'));
      event.target.classList.add('active');
      document.getElementById('readerContent').style.fontFamily = font + (font === 'Inter' ? ', sans-serif' : ', serif');
    }

    function setLineHeight(lh) {
      currentLineHeight = lh;
      document.querySelectorAll('.line-height-option').forEach(el => el.classList.remove('active'));
      event.target.classList.add('active');
      document.getElementById('readerContent').style.lineHeight = lh;
    }

    function updateProgress() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const pct = scrollHeight > 0 ? Math.round((scrollTop / scrollHeight) * 100) : 0;
      document.getElementById('progressBar').style.width = pct + '%';
      document.getElementById('progressText').textContent = '%' + pct;
    }

    window.addEventListener('scroll', updateProgress);
    window.addEventListener('resize', updateProgress);
    updateProgress();

    if (chapters.length) updateNavButtons();
    else {
      document.getElementById('prevBtn').classList.add('disabled');
      document.getElementById('nextBtn').classList.add('disabled');
    }

    document.addEventListener('click', function(e) {
      const panel = document.getElementById('settingsPanel');
      if (panel && !panel.contains(e.target) && !e.target.closest('[onclick="toggleSettings()"]')) {
        panel.classList.remove('active');
      }
    });
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/head', { title: book.title }) %>
</head>
<body>
  <% var bookChapters = locals.bookChapters || []; %>
  <%- include('partials/header') %>

  <main class="book-detail-page">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-cover" style="background: linear-gradient(135deg, <%= book.color %>, <%= book.color %>cc);">
          <div class="detail-cover-inner">
            <span class="detail-cover-title"><%= book.title %></span>
            <span class="detail-cover-author"><%= book.author %></span>
          </div>
        </div>
        <div class="detail-info">
          <div class="badge-row">
            <span class="badge badge-accent"><%= book.category %></span>
            <span class="badge badge-secondary"><%= book.year %></span>
            <span class="badge badge-secondary"><%= book.pages %> sayfa</span>
          </div>
          <h1 class="detail-title"><%= book.title %></h1>
          <p class="author"><%= book.author %></p>
          <p class="desc"><%= book.desc %></p>

          <div class="featured-meta">
            <div class="meta-item"><span class="value">★</span> <%= book.rating %> Puan</div>
            <div class="meta-item"><span class="value">◉</span> <%= (book.reads / 1000).toFixed(1) %>K okunma</div>
            <div class="meta-item"><span class="value">↓</span> <%= (book.downloads / 1000).toFixed(1) %>K indirme</div>
          </div>

          <div class="detail-actions">
            <a href="/read/<%= book.slug %>" class="btn btn-primary">Hemen Oku</a>
            <% if (book.pdfFile) { %>
              <a href="/download/<%= book.slug %>/pdf" class="btn btn-outline">PDF İndir</a>
            <% } %>
            <% if (book.epubFile) { %>
              <a href="/download/<%= book.slug %>/epub" class="btn btn-outline">EPUB İndir</a>
            <% } %>
            <% if (locals.isLoggedIn && (!book.addedBy || book.addedBy === locals.user.id)) { %>
              <form action="/book/<%= book.slug %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Bu kitabı ve kitaba ait tüm bölümleri silmek istediğinize emin misiniz?');">
                <button type="submit" class="btn btn-outline" style="border-color: #c85050; color: #c85050; transition: var(--transition-fast);" onmouseover="this.style.background='rgba(200,80,80,0.1)';" onmouseout="this.style.background='transparent';">Kitabı Sil</button>
              </form>
            <% } %>
          </div>

          <div class="tabs">
            <button class="tab active" onclick="switchTab(this, 'chapters')">Bölümler</button>
            <button class="tab" onclick="switchTab(this, 'about')">Hakkında</button>
          </div>

          <div id="chapters" class="tab-content active">
            <% if (bookChapters && bookChapters.length) { %>
              <ul class="chapter-list">
                <% bookChapters.forEach((ch, i) => { %>
                  <li class="chapter-item">
                    <a href="/read/<%= book.slug %>" class="chapter-link">
                      <div class="chapter-main">
                        <span class="chapter-num"><%= String(i+1).padStart(2, '0') %></span>
                        <span class="chapter-title"><%= ch.title %></span>
                      </div>
                      <span class="chapter-status"><span class="check">✓</span> Okunabilir</span>
                    </a>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="empty-state-sm">
                <p>Henüz bölüm eklenmemiş.</p>
              </div>
            <% } %>

            <% if (locals.isLoggedIn) { %>
              <div class="add-chapter-form" style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border);">
                <h3 style="font-family: var(--serif); font-size: 1.1rem; margin-bottom: 16px; color: var(--accent-bright);">Bölüm Ekle</h3>
                <form method="POST" action="/book/<%= book.slug %>/add-chapter">
                  <div class="form-group">
                    <label>Bölüm Başlığı</label>
                    <input type="text" name="chapterTitle" placeholder="Örn: Bölüm 1 - Başlangıç" required>
                  </div>
                  <div class="form-group">
                    <label>Bölüm İçeriği</label>
                    <textarea name="chapterContent" placeholder="Bölüm içeriğini buraya yaz..." rows="8" required></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary">Bölüm Ekle</button>
                </form>
              </div>
            <% } else { %>
              <p style="margin-top: 24px; color: var(--text-muted); font-family: var(--serif); font-style: italic; font-size: 0.9rem;">
                Bölüm eklemek için <a href="/login" style="color: var(--accent-bright);">giriş yap</a>.
              </p>
            <% } %>
          </div>

          <div id="about" class="tab-content">
            <p class="tab-text"><%= book.desc %> Eser, <%= book.year %> yılında yayımlanmıştır ve <%= book.pages %> sayfadan oluşmaktadır.</p>
          </div>
        </div>
      </div>

      <section class="section section-divider">
        <div class="section-header">
          <div>
            <div class="section-label">Benzer</div>
            <h2 class="section-title">Daha fazla <span class="accent">roman</span></h2>
          </div>
        </div>
        <div class="book-grid">
          <% similar.forEach(book => { %>
            <article class="book-card">
              <a href="/book/<%= book.slug %>" class="book-card-link">
                <div class="book-cover" style="background: linear-gradient(135deg, <%= book.color %>22, <%= book.color %>44); border-color: <%= book.color %>33;">
                  <div class="book-cover-inner">
                    <span class="book-cover-title" style="color: <%= book.color %>;"><%= book.title %></span>
                    <span class="book-cover-author" style="color: <%= book.color %>;"><%= book.author %></span>
                  </div>
                  <div class="book-overlay">
                    <span class="btn">Oku</span>
                  </div>
                </div>
                <div class="book-info">
                  <h3 class="book-title"><%= book.title %></h3>
                  <p class="book-author"><%= book.author %></p>
                  <div class="book-meta">
                    <span class="book-rating"><span class="star">★</span> <%= book.rating %></span>
                    <span class="book-tag"><%= book.category %></span>
                  </div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
  <script>
    function switchTab(el, id) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      el.classList.add('active');
      document.getElementById(id).classList.add('active');
    }
  </script>
</body>
</html>
